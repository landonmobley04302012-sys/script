-- Pattern-based target generation (continuous)
local nextNormalIndex = 1
local sideToSideDir = 1
local zigzagState = 1
function GetNextPosition()
    if not fieldPoints or #fieldPoints == 0 then return nil end

    if movementPattern == "Normal" or movementPattern == "Circle" then
        local pos = fieldPoints[nextNormalIndex]
        nextNormalIndex = nextNormalIndex % #fieldPoints + 1
        return pos
    elseif movementPattern == "Random" then
        return fieldPoints[math.random(1, #fieldPoints)]
    elseif movementPattern == "SideToSide" then
        local idx = sideToSideDir == 1 and 1 or #fieldPoints
        sideToSideDir = sideToSideDir == 1 and -1 or 1
        return fieldPoints[idx]
    elseif movementPattern == "Zigzag" then
        local idx = zigzagState == 1 and 1 or #fieldPoints
        zigzagState = zigzagState == 1 and -1 or 1
        return fieldPoints[idx]
    elseif movementPattern == "Star" then
        local center = fieldPoints[math.random(1, #fieldPoints)]
        local angle = math.random() * 2 * math.pi
        local radius = 8
        local offset = Vector3.new(math.cos(angle) * radius, 0, math.sin(angle) * radius)
        return center + offset
    elseif movementPattern == "Wander" then
        local root = game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if root then
            local center = fieldCenter
            local randomAngle = math.random() * 2 * math.pi
            local radius = math.random(20, 45)
            local offset = Vector3.new(math.cos(randomAngle) * radius, 0, math.sin(randomAngle) * radius)
            return center + offset
        else
            return fieldPoints[math.random(1, #fieldPoints)]
        end
    end
    return fieldPoints[1]
end

