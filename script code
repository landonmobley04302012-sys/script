-- ========== KEY MANAGER LOGIC ==========
local Players = game:GetService("Players")
local player = Players.LocalPlayer
local HttpService = game:GetService("HttpService")

local function getDeviceToken()
    local tokenFile = "device.txt"
    if isfile and isfile(tokenFile) then
        return readfile(tokenFile)
    else
        local newToken = HttpService:GenerateGUID()
        writefile(tokenFile, newToken)
        return newToken
    end
end
local deviceToken = getDeviceToken()

local function saveKey(key)
    if writefile then
        writefile("key.txt", key)
    end
end

local function loadKey()
    if isfile and isfile("key.txt") then
        return readfile("key.txt")
    end
    return nil
end

local function validateKey(key)
    if not key or key == "" then return false end
    local success, result = pcall(function()
        return game:HttpPost(API_BASE .. "/validate", HttpService:JSONEncode({
            key = key,
            deviceId = deviceToken
        }), {["Content-Type"] = "application/json"})
    end)
    if not success then return false end
    local data = HttpService:JSONDecode(result)
    return data.valid or false
end

local gameId = game.PlaceId
local gameScript = SUPPORTED_GAMES[gameId]

if not gameScript then
    local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
    local Window = Fluent:CreateWindow({
        Title = "Eclipse",
        SubTitle = "Unsupported Game",
        Size = UDim2.fromOffset(400, 200)
    })
    local tab = Window:AddTab({ Title = "Error", Icon = "error" })
    tab:AddParagraph({
        Title = "Unsupported Game",
        Content = string.format("This script is not supported for game ID %d.\nPlease use it in one of the supported games.", gameId)
    })
    return
end

local savedKey = loadKey()
if savedKey and validateKey(savedKey) then
    gameScript()
    return
end

