print("[DEBUG] Loader started")
local url = "https://raw.githubusercontent.com/landonmobley04302012-sys/ob-lua-scripts/main/bee%20swarm"
print("[DEBUG] URL: " .. url)

-- Try to find an HTTP function
local func = request or syn and syn.request or http_request or (game and game.HttpGet)
print("[DEBUG] Found HTTP function:", func and "yes" or "no")

if func then
    print("[DEBUG] Calling HTTP function")
    local response
    if func == request or func == http_request or (func == syn and syn.request) then
        local options = { Url = url, Method = "GET" }
        response = func(options)
        response = response and response.Body
    else
        response = func(url)
    end
    print("[DEBUG] Response length:", response and #response or "nil")
    if response then
        print("[DEBUG] Loading script...")
        loadstring(response)()
    else
        print("[DEBUG] Failed to fetch script")
    end
else
    print("[DEBUG] No HTTP function found")
end
