-- If the key was provided by the loader, use it
if script_key then
    local HttpService = game:GetService("HttpService")
    local Players = game:GetService("Players")
    local player = Players.LocalPlayer

    local API_BASE = "https://key-api-main.onrender.com"  -- YOUR RENDER URL

    local function getDeviceToken()
        local tokenFile = "device.txt"
        if isfile and isfile(tokenFile) then
            return readfile(tokenFile)
        else
            local newToken = HttpService:GenerateGUID()
            writefile(tokenFile, newToken)
            return newToken
        end
    end

    local function validateKey(key)
        local success, result = pcall(function()
            return game:HttpPost(API_BASE .. "/validate", HttpService:JSONEncode({
                key = key,
                deviceId = getDeviceToken()
            }), {["Content-Type"] = "application/json"})
        end)
        if not success then return false end
        local data = HttpService:JSONDecode(result)
        return data.valid or false
    end

    if validateKey(script_key) then
        -- Save the key
        if writefile then writefile("key.txt", script_key) end
        -- Proceed to the game script (Bee Swarm)
        local gameScript = SUPPORTED_GAMES[game.PlaceId]
        if gameScript then gameScript() end
    else
        warn("Invalid key provided in script_key.")
        game.StarterGui:SetCore("SendNotification", {
            Title = "Key Error",
            Text = "The key embedded in the script is invalid or expired.",
            Duration = 5
        })
    end
    return
end

