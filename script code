-- ========== UNIVERSAL HTTP FUNCTION ==========
local function httpRequest(url)
    local func = request or syn and syn.request or http_request or (game and game.HttpGet)
    if not func then error("No HTTP function available") end
    if func == request or func == http_request or (func == syn and syn.request) then
        local options = { Url = url, Method = "GET" }
        local response = func(options)
        return response and response.Body
    else
        return func(url)
    end
end

-- ========== FILE SYSTEM HELPERS ==========
local function fileExists(file) return isfile and isfile(file) end
local function readFile(file) if readfile then return readfile(file) end return nil end
local function writeFile(file, data) if writefile then writefile(file, data) end end

-- ========== CONFIGURATION ==========
local API_BASE = "https://key-api-main.onrender.com"
local OFFERS = {
    Linkvertise = "https://link-center.net/4622724/bsUCFRC0QrKk",
    Lootlabs = "https://lootdest.org/s?2LHy7lK0"
}
local GAME_SCRIPT_URL = "https://raw.githubusercontent.com/landonmobley04302012-sys/ob-lua-scripts/main/bee%20swarm"  -- <-- correct URL

-- ========== DEVICE TOKEN ==========
local function getDeviceToken()
    local tokenFile = "device.txt"
    if fileExists(tokenFile) then return readFile(tokenFile) end
    local newToken = HttpService:GenerateGUID()
    writeFile(tokenFile, newToken)
    return newToken
end
local deviceToken = getDeviceToken()

-- ========== KEY STORAGE ==========
local function saveKey(key) if key and key ~= "" then writeFile("key.txt", key) end end
local function loadKey() if fileExists("key.txt") then return readFile("key.txt") end return nil end

-- ========== VALIDATION (GET) ==========
local function validateKey(key)
    if not key or key == "" then return false end
    local url = API_BASE .. "/validate-get?key=" .. key .. "&deviceId=" .. deviceToken
    local result = httpRequest(url)
    if not result then return false end
    local data = HttpService:JSONDecode(result)
    return data.valid or false
end

-- ========== LOAD GAME SCRIPT ==========
local function loadGameScript()
    local script = httpRequest(GAME_SCRIPT_URL)
    if script then
        loadstring(script)()
    else
        warn("Failed to load game script")
        game.StarterGui:SetCore("SendNotification", {
            Title = "Error",
            Text = "Could not load the game script. Please contact support.",
            Duration = 5
        })
    end
end

-- ========== CHECK SAVED KEY ==========
local savedKey = loadKey()
if savedKey and validateKey(savedKey) then
    loadGameScript()
    return
end

