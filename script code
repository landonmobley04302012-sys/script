-- ========== UNIVERSAL HTTP FUNCTION (robust) ==========
local function httpRequest(method, url, body)
    local requestFunc = nil

    -- Try to find a working HTTP function
    local candidates = {
        syn and syn.request,
        http_request,
        request,
        game.HttpPost,
        function(_, _, data) return game:GetService("HttpService"):PostAsync(url, data, Enum.HttpContentType.ApplicationJson) end,
        function(_, _, data) return game:HttpGet(url, true) end -- fallback (GET only)
    }

    for _, f in ipairs(candidates) do
        if f and type(f) == "function" then
            requestFunc = f
            break
        end
    end

    if not requestFunc then
        warn("No HTTP function found. This script requires an executor that supports HTTP requests.")
        return { error = "No HTTP support" }
    end

    if method == "POST" then
        -- Try to send POST with body
        local success, result
        if requestFunc == game.HttpPost then
            success, result = pcall(requestFunc, url, body, "application/json")
        elseif requestFunc == game:GetService("HttpService").PostAsync then
            success, result = pcall(requestFunc, url, body, Enum.HttpContentType.ApplicationJson)
        else
            local options = {
                Url = url,
                Method = method,
                Headers = { ["Content-Type"] = "application/json" },
                Body = body
            }
            success, result = pcall(requestFunc, options)
            if success and result then result = result.Body or result end
        end
        if success then return result else return nil end
    else
        -- GET
        local success, result = pcall(game.HttpGet, url)
        if success then return result else return nil end
    end
end

-- ========== FILE SYSTEM HELPERS ==========
local function fileExists(file)
    return isfile and isfile(file)
end

local function readFile(file)
    if readfile then return readfile(file) end
    return nil
end

local function writeFile(file, data)
    if writefile then writefile(file, data) end
end

