            local humanoid = player.Character and player.Character:FindFirstChild("Humanoid")
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if not humanoid or not root then wait(1) continue end

            -- Apply walk speed (live update)
            if humanoid.WalkSpeed ~= walkSpeed then
                humanoid.WalkSpeed = walkSpeed
            end

            -- Auto‑resume: if we are far from the field center, re‑fly
            if fieldCenter and (root.Position - fieldCenter).magnitude > 50 then
                isInsideField = false
            end

            -- Always check for Vicious Bee (no toggle)
            if IsViciousNear() then
                if not evading then
                    evading = true
                    local evadeStart = tick()
                    while evading and IsViciousNear() and tick() - evadeStart < 30 do
                        local evadePos = GetNextPosition()
                        if evadePos then
                            WalkToPosition(evadePos)
                        end
                        wait(0.5)
                    end
                    evading = false
                end
                wait(0.5)
                continue
            end
            evading = false

            local maxPollen = GetMaxPollen(player)
            local currentPollen = GetCurrentPollen(player)

            -- Full backpack: teleport to hive and convert
            if currentPollen >= maxPollen then
                TeleportToHive()
                isInsideField = false
                wait(1)
                game:GetService("ReplicatedStorage").Events.PlayerHiveCommand:FireServer("ToggleHoneyMaking")
                repeat wait(0.5) until GetCurrentPollen(player) < 1
                wait(8)
                continue
            end

            -- Fly to field if not inside
            if not isInsideField then
                if fieldCenter then
                    FlyToPosition(fieldCenter)
                    isInsideField = true
                else
                    wait(1)
                    continue
                end
            end

            -- Continuous motion: get a target, walk towards it, and while walking,
            -- swing() at the interval defined above. When close, immediately pick next target.
            local targetPos = GetNextPosition()
            if not targetPos then
                PollenFarmActive = false
                break
            end

            WalkToPosition(targetPos)
            local distance = (root.Position - targetPos).magnitude
            -- Swing while moving, but also keep moving
            while distance > 5 and PollenFarmActive and not evading do
                swing()
                wait(0.15)
                distance = (root.Position - targetPos).magnitude
            end
            -- When close, swing a couple more times and then loop (next iteration will get new target)
            for _ = 1, 3 do
                if not PollenFarmActive then break end
                swing()
                wait(0.1)
            end
        end
    end
end)

