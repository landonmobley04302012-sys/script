local HttpService = game:GetService("HttpService")

local function getDeviceToken()
    local tokenFile = "device.txt"
    if isfile and isfile(tokenFile) then
        return readfile(tokenFile)
    else
        local newToken = HttpService:GenerateGUID()
        writefile(tokenFile, newToken)
        return newToken
    end
end
local deviceToken = getDeviceToken()

local function saveKey(key)
    if writefile then
        writefile("key.txt", key)
    end
end

local function loadKey()
    if isfile and isfile("key.txt") then
        return readfile("key.txt")
    end
    return nil
end

local function validateKey(key)
    if not key or key == "" then return false end
    local success, result = pcall(function()
        return game:HttpPost(API_BASE .. "/validate", HttpService:JSONEncode({
            key = key,
            deviceId = deviceToken
        }), {["Content-Type"] = "application/json"})
    end)
    if not success then return false end
    local data = HttpService:JSONDecode(result)
    return data.valid or false
end

