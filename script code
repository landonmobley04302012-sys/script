-- Debug loader
local function httpRequest(url)
    print("[DEBUG] Trying to fetch:", url)
    local func = request or syn and syn.request or http_request or (game and game.HttpGet)
    if not func then
        print("[DEBUG] No HTTP function found!")
        return nil
    end
    print("[DEBUG] Using HTTP function:", type(func))
    if func == request or func == http_request or (func == syn and syn.request) then
        local options = { Url = url, Method = "GET" }
        local response = func(options)
        print("[DEBUG] Response status:", response and response.StatusCode or "nil")
        return response and response.Body
    else
        local result = func(url)
        print("[DEBUG] Result length:", result and #result or "nil")
        return result
    end
end

local SCRIPT_URLS = {
    [1537690962] = "https://raw.githubusercontent.com/landonmobley04302012-sys/ob-lua-scripts/main/bee%20swarm",
}

local scriptUrl = SCRIPT_URLS[game.PlaceId]
print("[DEBUG] Game ID:", game.PlaceId)
print("[DEBUG] Script URL:", scriptUrl)

if scriptUrl then
    local scriptContent = httpRequest(scriptUrl)
    print("[DEBUG] Script content length:", scriptContent and #scriptContent or "nil")
    if scriptContent then
        print("[DEBUG] Loading script...")
        loadstring(scriptContent)()
    else
        print("[DEBUG] Failed to fetch script")
    end
else
    print("[DEBUG] Unsupported game")
end
